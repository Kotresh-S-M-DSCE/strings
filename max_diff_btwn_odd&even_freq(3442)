class Solution {
    public int maxDifference(String s) {
        int[] arr=new int[26];
        int odd=0,even=100;
        for(int i=0;i<s.length();i++)
            arr[s.charAt(i)-'a']++;
        for(int i=0;i<26;i++)
        {
            if(arr[i]%2!=0&&arr[i]>odd)
               odd=arr[i];
            if(arr[i]%2==0&&arr[i]<even&&arr[i]!=0)
               even=arr[i];
        }
        return (odd-even);
    }
}