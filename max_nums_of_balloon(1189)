class Solution {
    public int maxNumberOfBalloons(String text) {
        int[] arr=new int[26];
        for(int i=0;i<text.length();i++)
           arr[text.charAt(i)-'a']++;
        int min=Math.min(arr[0],arr[1]);
        int mini=Math.min(min,arr[13]);
        if(mini*2<=arr[11]&&mini*2<=arr[14])
           return mini;
        int temp=Math.min(arr[11],arr[14]);
        return temp/2;
    }
}