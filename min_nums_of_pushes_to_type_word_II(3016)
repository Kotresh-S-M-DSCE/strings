class Solution {
    public int minimumPushes(String word) {
        int[] arr=new int[26];
        for(int i=0;i<word.length();i++)
           arr[word.charAt(i)-'a']++;
        int count=1,ret=0;
        Arrays.sort(arr);
        for(int i=25;i>=0&&arr[i]!=0;i--)
        {
            if(i==17||i==9||i==1)
               count++;
            ret+=arr[i]*count;
        }
        return ret;
    }
}