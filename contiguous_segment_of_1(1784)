class Solution {
    public boolean checkOnesSegment(String s) {
        int count=0,i=0;
        while(i<s.length())
        {
            if(s.charAt(i)=='1')
            {
                count++;
                while(i!=s.length()&&s.charAt(i)=='1')
                    i++;
            }
            else
               i++;
            if(count>=2)
               return false;
        }
        return true;
    }
}