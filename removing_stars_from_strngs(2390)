class Solution {
    public String removeStars(String s) {
        int count=0;
        StringBuilder sb=new StringBuilder();
        for(int i=s.length()-1;i>=0;i--)
        {
            if(s.charAt(i)=='*')
               count++;
            else
            {
                if(count==0)
                   sb.insert(0,s.charAt(i));
                else
                   count--;
            }
        }
        return sb.toString();
    }
}