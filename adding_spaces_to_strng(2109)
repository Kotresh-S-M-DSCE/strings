class Solution {
    public String addSpaces(String s, int[] spaces) {
        int i=0,j=0;
        StringBuilder sb=new StringBuilder();
        while(i<s.length()&&j<spaces.length)
        {
            while(i!=spaces[j])
                sb.append(s.charAt(i++));
            sb.append(" ");
            j++;
        }
        while(i<s.length())
           sb.append(s.charAt(i++));
        return sb.toString();
    }
}