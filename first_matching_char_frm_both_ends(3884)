class Solution {
    public int firstMatchingIndex(String s) {
        if(s.length()==1)
            return 0;
        int n=s.length()-1;
        for(int i=0;i<s.length()/2;i++)
        {
            if(s.charAt(i)==s.charAt(n))
               return i;
            n--;
        }
        if(s.length()%2==1)
           return s.length()/2;
        return -1;
    }
}