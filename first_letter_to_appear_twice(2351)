class Solution {
    public char repeatedCharacter(String s) {
        int[] arr=new int[26];
        char ch=' ';
        for(int i=0;i<s.length();i++)
        {
            if(arr[s.charAt(i)-'a']==1)
            {
                ch=s.charAt(i);
                break;
            }
            arr[s.charAt(i)-'a']++;
        }
        return ch;
    }
}