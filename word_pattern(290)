class Solution {
    public boolean wordPattern(String pattern, String s) {
        Map<String,String> map=new HashMap<>();
        Map<String,String> rev=new HashMap<>();
        int j=0;
        for(int i=0;i<pattern.length();i++)
        {
            StringBuilder sb=new StringBuilder();
            if(j>s.length())
               return false;
            while(j<s.length()&&s.charAt(j)!=' ')
                sb.append(s.charAt(j++));
            if(!map.containsKey(Character.toString(pattern.charAt(i)))&&!rev.containsKey(sb.toString()))
            {
                rev.put(sb.toString(),Character.toString(pattern.charAt(i)));
                map.put(Character.toString(pattern.charAt(i)),sb.toString());
            }
            else 
            {
                if(map.containsKey(Character.toString(pattern.charAt(i)))&&(!map.get(Character.toString(pattern.charAt(i))).equals(sb.toString())))
                   return false;
                if(rev.containsKey(sb.toString())&&(!rev.get(sb.toString()).equals(Character.toString(pattern.charAt(i)))))
                   return false;
            }
            j++;
        }
        if(j<s.length())
           return false;
        return true;
    }
}